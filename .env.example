# ─── Database ───
MONGODB_URL=mongodb://localhost:27017
DB_NAME=court_automation

# ─── Cache ───
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ─── Celery ───
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Email Notifications ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=Court Automation <your-email@gmail.com>

# ─── Twilio (WhatsApp) ───
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── OpenAI ───
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Google Drive ───
GOOGLE_DRIVE_CREDENTIALS=./credentials/google_drive_service.json
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# ─── Google Calendar ───
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_CREDENTIALS=./credentials/google_calendar_service.json

# ─── n8n ───
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ─── API Settings ───
API_BASE_URL=http://localhost:8000/api/v1
MAX_REQUESTS_PER_MINUTE=30
MAX_REQUESTS_PER_USER=10
ALLOWED_USERS=

# ─── PDF Output ───
PDF_OUTPUT_DIR=./data/pdfs

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
